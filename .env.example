APP_NAME="Barangay Reservation"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=brgy_central
DB_USERNAME=root
DB_PASSWORD=

# Comma-separated hosts that resolve to the CENTRAL app (super admin), not tenant barangays
CENTRAL_DOMAINS=central.localhost,localhost,127.0.0.1

# Full base URL of the central app (for signed links from tenant domains — must match how you open central in the browser)
# CENTRAL_APP_URL=http://localhost:8000

# Auto-generated tenant domains use: {slug-from-name}.{TENANT_DOMAIN_SUFFIX}
TENANT_DOMAIN_SUFFIX=localhost

# Placeholder DB name for artisan; real tenant DB names are set at runtime per domain
TENANT_DB_PLACEHOLDER=tenant_placeholder

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# smtp + Gmail: set MAIL_USERNAME, MAIL_PASSWORD (Google App Password), MAIL_FROM_ADDRESS to the same Gmail.
# log = messages only in storage/logs/laravel.log
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_TIMEOUT=8
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Tenant security and social login
RECAPTCHA_ENABLED=false
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Example callback for tenant domain:
# GOOGLE_REDIRECT_URI=http://carmen.localhost:8000/auth/google/callback
GOOGLE_REDIRECT_URI=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Stripe (tenant application fee — add when ready; used by /apply landing UI and future Checkout)
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
# Optional: smallest currency units (e.g. 50000 = PHP 500.00 if currency is php)
STRIPE_APPLICATION_FEE_AMOUNT=
STRIPE_APPLICATION_FEE_CURRENCY=php
